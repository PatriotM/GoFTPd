file: "./data/news.jsonl"
default_shown: 5
max_shown: 20
search_default: 4
# reply_target controls where command replies go:
#   "channel"  = reply in the channel where the command was used
#   "notice"   = reply as a private NOTICE to the user
#   "#channel" = always reply in that fixed IRC channel
reply_target: "channel"
channels: ["#goftpd"]
staff_channels: ["#goftpd-staff"]
staff_hosts: []

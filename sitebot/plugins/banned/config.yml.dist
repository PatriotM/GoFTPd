# Public IRC gateway for SITE BANNED.
# IRC commands:
#   !banned
#   !banned <filter>
#   !banned allow [filter]
host: "127.0.0.1"
port: 21212
user: "goftpd"
password: "goftpd"
tls: true
insecure_skip_verify: true
timeout_seconds: 10
channels: ["#goftpd"]
# reply_target supports "channel", "notice", "pm", or a fixed "#channel".
reply_target: "pm"

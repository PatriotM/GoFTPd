# Public IRC gateway for site rules.
# IRC command:
#   !rules
# If rules_file is set, the plugin reads that file directly.
# Otherwise it falls back to SITE RULES over FTP.
host: "127.0.0.1"
port: 21212
user: "goftpd"
password: "goftpd"
tls: true
insecure_skip_verify: true
timeout_seconds: 10
channels: ["#goftpd"]
# reply_target supports "channel", "notice", "pm", or a fixed "#channel".
reply_target: "pm"
rules_file: ""

# Where replies from !free should go.
# reply_target supports "channel", "notice", or a fixed "#channel".
reply_target: "channel"

# Treat disk status older than this as stale/down.
stale_after_seconds: 600

# Output controls. Disable show_slave_lines when you only want named groups
# like RACE / ARCHiVE / OFFSiTE ARCHiVE and not the raw slave name line.
show_slave_lines: true
show_named_groups: true
show_total: true

# Optional named groups shown by !df.
#
# You can group roots in two different ways:
#
#   mount_paths:
#     Match the virtual path exposed by the slave config.
#     Use this for logical groups like "/" for the normal site root, or
#     "/ARCHiVE" to sum every mounted_root that is mounted under /ARCHiVE.
#
#   paths:
#     Match the exact real/local root path reported by the slave.
#     Use this when you want to name specific disks directly, for example
#     "/glftpd/DISK1". These are exact matches, not glob patterns.
#
# If your slave has:
#   roots: ["/glftpd/site"]
#   mounted_roots:
#     - path: "/glftpd/DISK1"
#       mount_path: "/ARCHiVE"
#     - path: "/glftpd/DISK2"
#       mount_path: "/ARCHiVE"
#
# Then mount_paths: ["/ARCHiVE"] sums DISK1+DISK2 by virtual mount name,
# while paths: ["/glftpd/DISK1"] only counts that one real disk.
#
# named_groups:
#   - name: "RACE"
#     mount_paths: ["/"]
#   - name: "ARCHiVE"
#     mount_paths: ["/ARCHiVE"]
#   - name: "OFFSiTE ARCHiVE"
#     mount_paths: ["/OFFSITE"]
#   - name: "LOCAL ARCH DISKS"
#     paths: ["/glftpd/DISK1", "/glftpd/DISK2", "/glftpd/DISK3"]

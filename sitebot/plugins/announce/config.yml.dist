# Fallback channel for announce types that do not have a more specific route.
default_channel: "#goftpd-staff"

# Shared theme file used to render formatted announce lines.
# Bundled presets:
#   ./etc/templates/pzsng.theme
#   ./etc/templates/drftpd.theme
theme_file: "./etc/templates/pzsng.theme"

# Collapse repeated LOGINFAIL announces for the same username/reason/source
# within this many seconds, so staff does not get flooded by retry storms.
loginfail_cooldown_seconds: 10

# Explicit type -> channel routes.
type_routes:
  NUKE: ["#goftpd-nuke"]
  UNNUKE: ["#goftpd-nuke"]
  NEWDAY: ["#goftpd"]
  SPEEDTEST: ["#goftpd"]
  TOP: ["#goftpd-chat"]
  LOGIN: ["#goftpd-staff"]
  SELFIP: ["#goftpd-staff"]
  SLAVEAUTH: ["#goftpd-staff"]
  SLOWUPLOADWARN: ["#goftpd-staff"]
  SLOWUPLOADKICK: ["#goftpd-staff"]
  SLOWDOWNLOADWARN: ["#goftpd-staff"]
  SLOWDOWNLOADKICK: ["#goftpd-staff"]

# Pretime rendering mode:
#   newline = emit a second PRETiME line with OK/BAD
#   inline  = hold NEW briefly and replace it with a single NEW ... released ...
pretime:
  mode: "newline"


debug: true
log_file:      "logs/sitebot.log"
log_keep_days: 1

event_fifo: "/GoFTPd/etc/goftpd.sitebot.fifo"

irc:
  host: "45.45.54.54"
  port: 48400
  nick: "GoSitebot"
  user: "sitebot"
  realname: "GoSitebot v1.0"
  password: "changeme"
  ssl: true
  auto_oper: false
  operuser: "GoSitebot"
  operpassword: "changeme-oper"
  user_modes: "+Hi"
  autojoin_delay_ms: 250
  channels:
    - "#goftpd"
    - "#goftpd-announce"

# ============================================================================
# SITE INVITE channel visibility
# ============================================================================
# Channels listed here are restricted to users with at least one of the given
# flags. Any channel NOT listed is considered public and returned to everyone.
# Flags are matched character-by-character — "12" means flag 1 OR flag 2.
#
# Example: keep #goftpd and #goftpd-spam public, restrict #goftpd-staff to
# siteops only. SITE INVITE then returns:
#   - siteop       -> #goftpd, #goftpd-spam, #goftpd-staff
#   - regular user -> #goftpd, #goftpd-spam
# ============================================================================
invite_channels:
  - channel: "#goftpd-staff"
    flags: "1"

encryption:
  enabled: true
  keys:
    "#goftpd": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-spam": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-staff": "cbc:YourBlowfishKeyHere123456"

announce:
  default_channel: "#goftpd-staff"
  theme_file: "./etc/templates/pzsng.theme"
  type_routes:
    NUKE:
      - "#goftpd-nuke"
    UNNUKE:
      - "#goftpd-nuke"
    NEWDAY:
      - "#goftpd"
    SPEEDTEST:
      - "#goftpd"

sections:
  - name: "DEFAULT"
    channels:
      - "#goftpd-staff"
    paths: []
  - name: "TV-1080P"
    channels:
      - "#goftpd"
    paths:
      - "/TV-1080P/*"
  - name: "MP3"
    channels:
      - "#goftpd-spam"
    paths:
      - "/MP3/*"
  - name: "SPEEDTEST"
    channels:
      - "#goftpd"
    paths:
      - "/SPEEDTEST/*"


plugins:
  enabled:
    Announce: true
    TVMaze: true
    IMDB: true
    News: true
    Free: true
    Affils: true
  config:
    debug: true


    # Section matching is case-insensitive substring based.
    # "TV" matches TV-1080P, TV-720P, TV-X265, etc.
    tvmaze:
      sections: ["TV-1080P", "TV-720P"]

    imdb:
      sections: ["X264-SD", "X265", "BLURAY"]

    news:
      file: "./data/news.jsonl"
      default_shown: 5
      max_shown: 20
      search_default: 4
      # reply_target controls where command replies go:
      #   "channel"  = reply in the channel where the command was used
      #   "notice"   = reply as a private NOTICE to the user
      #   "#channel" = always reply in that fixed IRC channel
      reply_target: "channel"
      channels: ["#goftpd"]
      staff_channels: ["#goftpd-staff"]
      staff_hosts: []

    free:
      # reply_target supports "channel", "notice", or a fixed "#channel".
      reply_target: "#goftpd"
      stale_after_seconds: 600

    affils:
      # Shared affil file. If the sitebot is started from ./sitebot, use ../etc/affils.yml.
      file: "../etc/affils.yml"
      # reply_target supports "channel", "notice", or a fixed "#channel".
      reply_target: "channel"
      show_predirs: false

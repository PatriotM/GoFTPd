debug: true
log_file:      "logs/sitebot.log"
log_delete_after_days: 1
log_keep_days: 1
log_console:   true

event_fifo: "/GoFTPd/etc/goftpd.sitebot.fifo"

# Channel sets are YAML anchors. The sitebot ignores this top-level block, but
# YAML expands the anchors anywhere they are referenced below.
channel_sets:
  main:    &chan_main    ["#goftpd"]
  spam:    &chan_spam    ["#goftpd-spam"]
  staff:   &chan_staff   ["#goftpd-staff"]
  foreign: &chan_foreign ["#goftpd-foreign"]
  archive: &chan_archive ["#goftpd-archive"]
  nuke:    &chan_nuke    ["#goftpd-nuke"]

irc:
  host: "irc.example.net"
  port: 6697
  nick: "GoSitebot"
  user: "sitebot"
  realname: "GoSitebot v1.0"
  password: "changeme"
  ssl: true
  auto_oper: false
  operuser: "GoSitebot"
  operpassword: "changeme-oper"
  user_modes: "+Hi"
  autojoin_delay_ms: 250
  channels:
    - "#goftpd"
    - "#goftpd-spam"
    - "#goftpd-staff"

# ============================================================================
# SITE INVITE channel visibility
# ============================================================================
# Channels listed here are restricted to users with at least one of the given
# flags. Any channel NOT listed is considered public and returned to everyone.
# Flags are matched character-by-character: "12" means flag 1 OR flag 2.
# ============================================================================
invite_channels:
  - channel: "#goftpd-staff"
    flags: "1"

encryption:
  enabled: true
  keys:
    "#goftpd": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-spam": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-staff": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-foreign": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-archive": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-nuke": "cbc:YourBlowfishKeyHere123456"

announce:
  config_file: "plugins/announce/config.yml"

sections:
  - name: "DEFAULT"
    channels: *chan_staff
    paths: []

#########################
# #goftpd-foreign
#########################

  - name: "TV-CZ"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-CZ/*"

  - name: "TV-DE"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-DE/*"

  - name: "TV-DK"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-DK/*"

  - name: "TV-ES"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-ES/*"

  - name: "TV-FI"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-FI/*"

  - name: "TV-FR"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-FR/*"

  - name: "TV-IT"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-IT/*"

  - name: "TV-NL"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-NL/*"

  - name: "TV-NO"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-NO/*"

  - name: "TV-PL"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-PL/*"

  - name: "TV-SE"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-SE/*"

  - name: "TV-SK"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-SK/*"

  - name: "X264-HD-FOREIGN"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/X264-HD-FOREIGN/*"

  - name: "X264-SD-FOREIGN"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/X264-SD-FOREIGN/*"

  - name: "X265-FOREIGN"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/X265-FOREIGN/*"

#########################
# #goftpd-archive
#########################

  - name: "ARCHIVE"
    channels: *chan_archive
    paths:
      - "/ARCHiVE/*"

#########################
# #goftpd
#########################

  - name: "APPS"
    channels: *chan_main
    paths:
      - "/APPS/*"

  - name: "BLURAY"
    channels: *chan_main
    paths:
      - "/BLURAY/*"

  - name: "BLURAY-UHD"
    channels: *chan_main
    paths:
      - "/BLURAY-UHD/*"

  - name: "DVDR"
    channels: *chan_main
    paths:
      - "/DVDR/*"

  - name: "GAMES"
    channels: *chan_main
    paths:
      - "/GAMES/*"

  - name: "MBLURAY"
    channels: *chan_main
    paths:
      - "/MBLURAY/*"

  - name: "MDVDR"
    channels: *chan_main
    paths:
      - "/MDVDR/*"

  - name: "NSW"
    channels: *chan_main
    paths:
      - "/NSW/*"

  - name: "PRE"
    channels: *chan_main
    paths:
      - "/PRE/*/*"

  - name: "PS5"
    channels: *chan_main
    paths:
      - "/PS5/*"

  - name: "REQUESTS"
    channels: *chan_main
    paths:
      - "/REQUESTS/*/*"

  - name: "SPEEDTEST"
    channels: *chan_main
    paths:
      - "/SPEEDTEST/*"

  - name: "TV-1080P"
    channels: *chan_main
    paths:
      - "/TV-1080P/*"

  - name: "TV-2160P"
    channels: *chan_main
    paths:
      - "/TV-2160P/*"

  - name: "TV-720P"
    channels: *chan_main
    paths:
      - "/TV-720P/*"

  - name: "TV-BLURAY"
    channels: *chan_main
    paths:
      - "/TV-BLURAY/*"

  - name: "TV-HDRIP"
    channels: *chan_main
    paths:
      - "/TV-HDRIP/*"

  - name: "TV-SD"
    channels: *chan_main
    paths:
      - "/TV-SD/*"

  - name: "TV-SPORTS"
    channels: *chan_main
    paths:
      - "/TV-SPORTS/*"

  - name: "X264-HD-1080P"
    channels: *chan_main
    paths:
      - "/X264-HD-1080P/*"

  - name: "X264-HD-720P"
    channels: *chan_main
    paths:
      - "/X264-HD-720P/*"

  - name: "X264-SD"
    channels: *chan_main
    paths:
      - "/X264-SD/*"

  - name: "X265"
    channels: *chan_main
    paths:
      - "/X265/*"

#########################
# #goftpd-spam
#########################

  - name: "MP3"
    channels: *chan_spam
    paths:
      - "/MP3/*/*"

  - name: "EBOOKS"
    channels: *chan_spam
    paths:
      - "/EBOOKS/*/*"

  - name: "FLAC"
    channels: *chan_spam
    paths:
      - "/FLAC/*/*"

  - name: "XXX-0DAY"
    channels: *chan_spam
    paths:
      - "/XXX-0DAY/*/*"

  - name: "0DAY"
    channels: *chan_spam
    paths:
      - "/0DAY/*/*"

  - name: "XXX-HD"
    channels: *chan_spam
    paths:
      - "/XXX-HD/*"

  - name: "XXX-IMAGESETS"
    channels: *chan_spam
    paths:
      - "/XXX-IMAGESETS/*"

  - name: "XXX-SD"
    channels: *chan_spam
    paths:
      - "/XXX-SD/*"

  - name: "MVID"
    channels: *chan_spam
    paths:
      - "/MVID/*"

plugins:
  enabled:
    Announce: true
    TVMaze: true
    IMDB: true
    News: true
    Free: true
    Affils: true
    Request: true
    BNC: true
    BW: true
    AdminCommander: true
  config:
    debug: true
    # Plugin defaults live in sitebot/plugins/<name>/config.yml.dist.
    # Copy them to config.yml so Git updates do not overwrite your local values.
    tvmaze:
      config_file: "plugins/tvmaze/config.yml"
    imdb:
      config_file: "plugins/imdb/config.yml"
    news:
      config_file: "plugins/news/config.yml"
    free:
      config_file: "plugins/free/config.yml"
    affils:
      config_file: "plugins/affils/config.yml"
    request:
      config_file: "plugins/request/config.yml"
    bnc:
      config_file: "plugins/bnc/config.yml"
    bandwidth:
      config_file: "plugins/bw/config.yml"
    admin_commander:
      config_file: "plugins/admincommander/config.yml"

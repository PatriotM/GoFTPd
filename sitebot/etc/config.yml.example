      - "/FLAC/*/*"

  - name: "XXX-0DAY"
    channels: *chan_spam
    paths:
      - "/XXX-0DAY/*/*"

  - name: "0DAY"
    channels: *chan_spam
    paths:
      - "/0DAY/*/*"

  - name: "XXX-HD"
    channels: *chan_spam
    paths:
      - "/XXX-HD/*"

  - name: "XXX-IMAGESETS"
    channels: *chan_spam
    paths:
      - "/XXX-IMAGESETS/*"

  - name: "XXX-SD"
    channels: *chan_spam
    paths:
      - "/XXX-SD/*"

  - name: "MVID"
    channels: *chan_spam
    paths:
      - "/MVID/*"

plugins:
  enabled:
    Announce: true
    TVMaze: true
    IMDB: true
    News: true
    Free: true
    Affils: true
    Request: true
    BNC: true
    Control: true
    Banned: true
    SelfIP: true
    Quota: false
    Top: true
    BW: true
    Rules: true
    Topic: true
    AdminCommander: true
  config:
    debug: false
    # Plugin defaults live in sitebot/plugins/<name>/config.yml.dist.
    # Copy them to config.yml so Git updates do not overwrite your local values.
    tvmaze:
      config_file: "plugins/tvmaze/config.yml"
    imdb:
      config_file: "plugins/imdb/config.yml"
    news:
      config_file: "plugins/news/config.yml"
    free:
      config_file: "plugins/free/config.yml"
    affils:
      config_file: "plugins/affils/config.yml"
    request:
      config_file: "plugins/request/config.yml"
    bnc:
      config_file: "plugins/bnc/config.yml"
    control:
      config_file: "plugins/control/config.yml"
    banned:
      config_file: "plugins/banned/config.yml"
    quota:
      config_file: "plugins/quota/config.yml"
    top:
      config_file: "plugins/top/config.yml"
    bandwidth:
      config_file: "plugins/bw/config.yml"
    rules:
      config_file: "plugins/rules/config.yml"
    selfip:
      config_file: "plugins/selfip/config.yml"
    topic:
      config_file: "plugins/topic/config.yml"
    admin_commander:
      config_file: "plugins/admincommander/config.yml"

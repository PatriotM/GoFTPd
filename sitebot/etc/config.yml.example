      - "/PS5/*"

  - name: "REQUESTS"
    channels: *chan_main
    paths:
      - "/REQUESTS/*/*"

  - name: "SPEEDTEST"
    channels: *chan_main
    paths:
      - "/SPEEDTEST/*"

  - name: "TV-1080P"
    channels: *chan_main
    paths:
      - "/TV-1080P/*"

  - name: "TV-2160P"
    channels: *chan_main
    paths:
      - "/TV-2160P/*"

  - name: "TV-720P"
    channels: *chan_main

  - name: "X264-SD-FOREIGN"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/X264-SD-FOREIGN/*"

  - name: "X265-FOREIGN"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/X265-FOREIGN/*"

#########################
# #goftpd-archive
#########################

  - name: "ARCHIVE"
    channels: *chan_archive
    paths:
      - "/ARCHiVE/*"

#########################
# #goftpd
#########################

  - name: "APPS"
    channels: *chan_main
    paths:
      - "/APPS/*"

  - name: "BLURAY"
    channels: *chan_main
    paths:
      - "/BLURAY/*"

  - name: "BLURAY-UHD"
    channels: *chan_main
    paths:
      - "/BLURAY-UHD/*"

  - name: "DVDR"
    channels: *chan_main
    paths:
      - "/DVDR/*"

  - name: "GAMES"
    channels: *chan_main
    paths:
      - "/GAMES/*"

  - name: "MBLURAY"
    channels: *chan_main
    paths:
      - "/MBLURAY/*"

  - name: "MDVDR"
    channels: *chan_main
    paths:
      - "/MDVDR/*"

  - name: "NSW"
    channels: *chan_main
    paths:
      - "/NSW/*"

  - name: "PRE"
    channels: *chan_main
    paths:
      - "/PRE/*/*"

  - name: "PS5"
    channels: *chan_main

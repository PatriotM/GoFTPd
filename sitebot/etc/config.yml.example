debug: false
log_file:      "logs/sitebot.log"
log_delete_after_days: 1
log_keep_days: 1
log_console:   true
version:       "1.0.6b"

event_fifo: "/GoFTPd/etc/goftpd.sitebot.fifo"

# Channel sets are YAML anchors. The sitebot ignores this top-level block, but
# YAML expands the anchors anywhere they are referenced below.
channel_sets:
  main:    &chan_main    ["#goftpd"]
  chat:    &chan_chat    ["#goftpd-chat"]
  spam:    &chan_spam    ["#goftpd-spam"]
  staff:   &chan_staff   ["#goftpd-staff"]
  foreign: &chan_foreign ["#goftpd-foreign"]
  archive: &chan_archive ["#goftpd-archive"]
  nuke:    &chan_nuke    ["#goftpd-nuke"]

irc:
  host: "irc.example.net"
  port: 6697
  nick: "GoSitebot"
  user: "sitebot"
  realname: "GoSitebot v1.0.6b"
  password: "changeme"
  ssl: true
  auto_oper: false
  operuser: "GoSitebot"
  operpassword: "changeme-oper"
  user_modes: "+Hi"
  autojoin_delay_ms: 250
  channels:
    - "#goftpd"
    - "#goftpd-chat"
    - "#goftpd-spam"
    - "#goftpd-staff"
    - "#goftpd-foreign"
    - "#goftpd-archive"
    - "#goftpd-nuke"

# ============================================================================
# SITE INVITE channel visibility
# ============================================================================
# Channels listed here are restricted to users with at least one of the given
# flags. Any channel NOT listed is considered public and returned to everyone.
# Flags are matched character-by-character: "12" means flag 1 OR flag 2.
# ============================================================================
invite_channels:
  - channel: "#goftpd-staff"
    flags: "1"

encryption:
  enabled: true
  # Auto-exchange FiSH keys for PM/NOTICE traffic with users via DH1080.
  # This is peer-to-peer only; channel/topic FiSH still uses the static keys
  # below because DH1080 does not negotiate a shared channel key.
  # If this setting is omitted, the sitebot defaults it to true.
  auto_exchange: true
  # Enter keys in "cbc:<key>" format in the final config file.
  # setup.sh asks for raw keys and writes the cbc: prefix for you.
  # private_key is used for PM/NOTICE replies to users and for decrypting
  # incoming encrypted PM commands sent directly to the bot nick.
  # Leave this empty if you want to rely on DH1080 auto-exchange instead.
  private_key: "cbc:YourBlowfishKeyHere123456"
  keys:
    "#goftpd": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-chat": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-spam": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-staff": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-foreign": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-archive": "cbc:YourBlowfishKeyHere123456"
    "#goftpd-nuke": "cbc:YourBlowfishKeyHere123456"

announce:
  config_file: "plugins/announce/config.yml"
  # Pretime inline/newline mode lives in plugins/announce/config.yml:
  #   pretime:
  #     mode: "inline"
  #     inline_wait_ms: 1500

help:
  channels: *chan_chat
  reply_target: "pm"
  lines:
    - "!help - show this help in PM"
    - "!rules - show site rules in PM"
    - "!top [5|10|25] - show daily top uploaders"
    - "!request <release> - add a request"
    - "!requests - list requests"
    - "!ip - PM help for self-service IP commands"

sections:
  - name: "DEFAULT"
    channels: *chan_staff
    paths: []

#########################
# #goftpd-chat
#########################

  - name: "REQUESTS"
    channels: *chan_chat
    paths:
      - "/REQUESTS/*/*"

  - name: "SPEEDTEST"
    channels: *chan_chat
    paths:
      - "/SPEEDTEST/*"

#########################
# #goftpd-foreign
#########################

  - name: "TV-CZ"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-CZ/*"

  - name: "TV-DE"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-DE/*"

  - name: "TV-DK"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-DK/*"

  - name: "TV-ES"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-ES/*"

  - name: "TV-FI"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-FI/*"

  - name: "TV-FR"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-FR/*"

  - name: "TV-IT"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-IT/*"

  - name: "TV-NL"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-NL/*"

  - name: "TV-NO"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-NO/*"

  - name: "TV-PL"
    channels: *chan_foreign
    paths:
      - "/FOREIGN/TV-PL/*"

  - name: "TV-SE"
    channels: *chan_foreign

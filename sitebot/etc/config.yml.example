      - "/TV-720P/*"

  - name: "TV-BLURAY"
    channels: *chan_main
    paths:
      - "/TV-BLURAY/*"

  - name: "TV-HDRIP"
    channels: *chan_main
    paths:
      - "/TV-HDRIP/*"

  - name: "TV-SD"
    channels: *chan_main
    paths:
      - "/TV-SD/*"

  - name: "TV-SPORTS"
    channels: *chan_main
    paths:
      - "/TV-SPORTS/*"

  - name: "X264-HD-1080P"
    channels: *chan_main
    paths:
      - "/X264-HD-1080P/*"

  - name: "X264-HD-720P"
    channels: *chan_main
    paths:
      - "/X264-HD-720P/*"

  - name: "X264-SD"
    channels: *chan_main

announce.QUOTACMD_QUOTA_ENTRY = "%c14{[}%b%c03{%rank}%b%c14{]} %user%c01{/}%c07{%group} %c01{( }%c06{%size} %c01{Up ) is currently }%status_colored%c01{.}"

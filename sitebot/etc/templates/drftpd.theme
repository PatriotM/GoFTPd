announce.NEWDIR = "%b{%c15{NEW}} %c01{in }%section_colored%c01{: -> }%b{%path}%b %c01{by }%b{%user}%b%c14{/}%b{%group}%b."

announce.NEWDAY = "%b{%c01{NEW DAY:}} %c01{-}%section_colored%c01{- A new day has come!} %c%sec_c5{%date} %c01{has been created along with its symlink.}"

announce.AUDIOINFO = "%b{%c15{FLAC}} %c01{-> }%b{%relname}%b %c01{[}%b{%genre}%b %c01{from }%b{%year}%b %c01{at sample rate }%b{%sample_rate}%b %c01{Hz, channels }%b{%channels}%b%c01{]}"

announce.MEDIAINFO = "%b{[SAMPLE]} %b{%path}%b %c01{::} %b{%video_format}%b %c01{: }%widthx%height %c01{: }%b{%audio_format}%b %c01{: }%b{%channels}%b %c01{: }%b{%duration}%b"

announce.SPEEDTEST = "%b{%c01{SPEEDTEST:}} %c04{%nick} %c01{%action} %c01{a} %c05{%{size_mb}MB} %c01{file with} %c06{%speed_mbs}"

announce.SFV_RAR = "%b{%c15{RACE:}} %c01{[}%section_colored%c01{]} %c01{Got SFV for }%c%sec_c3{%b{%relname}} %c01{uploaded by }%c%sec_c4{%u_name}%c01{. Now expecting }%c%sec_c5{%b{%t_filecount}} %c01{%t_file_label.}"

announce.UPDATE_RAR = "%b{%c15{FIRST}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b %c01{at }%b{%speed}%b%c01{. Expecting }%b{%size}%b %c01{in }%b{%files}%b %c01{files.}"

announce.UPDATE_RAR_UNKNOWN = "%b{%c15{FIRST}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b %c01{at }%b{%speed}%b."

announce.UPDATE_ZIP = "%b{%c15{FIRST}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b %c01{at }%b{%speed}%b%c01{. Expecting }%b{%size}%b %c01{in }%b{%files}%b %c01{files.}"

announce.UPDATE_ZIP_UNKNOWN = "%b{%c15{FIRST}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b %c01{at }%b{%speed}%b."

announce.UPDATE_TRACK = "%b{%c15{FIRST}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b %c01{at }%b{%speed}%b."

announce.RACE_RAR = "%b{%c15{RACE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{- }%c%sec_c4{%u_name} %c01{joined the race at }%c%sec_c5{%u_speed}%c01{.}"

announce.NEWLEADER = "%b{%c15{NEW LEADER:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{- }%c%sec_c4{%leaduser} %c01{takes the lead - }%c%sec_c5{%leadsize}%c01{/}%c%sec_c5{%leadfiles}F%c01{/}%c%sec_c5{%leadpercent}%c01{/}%c%sec_c5{%leadspeed}%c01{.}"

announce.HALFWAY = "%b{%c15{HALFWAY:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{- avg speed: }%c%sec_c5{%t_avgspeed} %c01{- time left: }%c%sec_c5{%t_timeleft} %c01{- leader: }%c%sec_c4{%leaduser} %c01{[}%c%sec_c5{%leadsize}%c01{/}%c%sec_c5{%leadfiles}F%c01{/}%c%sec_c5{%leadpercent}%c01{/}%c%sec_c5{%leadspeed}%c01{] - }%c%sec_c5{%filesleft} %c01{files left.}"

announce.TVINFO = "%section_colored %c14{-TvMaze-} %c07{%title}%c01{ :: }%c07{%network}%c01{ :: }%c07{%type}%c01{ :: }%c07{%genre}%c01{ :: }%c07{%language}%c01{ :: }%link"

announce.MOVIEINFO = "%section_colored %c14{-IMDB-} %c07{%title}%c01{ (}%c07{%year}%c01{)}\n%section_colored %c14{-IMDB-} %c01{Genres: }%c07{%genre}%c01{ :: Language: }%c07{%language}%c01{ :: Country: }%c07{%country}%c01{ :: Director: }%c07{%director}%c01{ :: Scored: }%c07{%rating}/10%c01{ with }%c07{%votes}%c01{ votes :: Runtime: }%c07{%runtime}\n%section_colored %c14{-IMDB-} %c01{Plot: }%plot\n%u{%link}"

announce.COMPLETE = "%b{%c15{COMPLETE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{by }%c%sec_c5{%racers} %c01{racers - }%c%sec_c5{%size}%c01{/}%c%sec_c5{%files}%c01{/}%c%sec_c5{%t_avgspeed}%c01{/}%c%sec_c5{%t_duration}"

announce.STATS_HOF = "%b{%c01{STATS:}} ===== %c03{Users Hall Of Fame} %c01{=====}"

announce.STATS_SPEEDS = "%b{%c01{STATS:}} %c01{Slowest:} %c%sec_c4{%u_slowest_name} %c01{at} %c05{%u_slowest_speed} %c01{-} %c01{Fastest:} %c%sec_c4{%u_fastest_name} %c01{at} %c05{%u_fastest_speed}%c01{.}"

announce.STATS_USER = "%b{%c01{STATS:}} %b{%{u_rank}}%c01{. }%b{%{u_name}}%c01{@}%c06{%{u_group}} %c01{[}%{u_mb}MB%c01{/}%{u_files} %c01{Files/}%{u_pct}%c01{%/}%{u_speed}%c01{] [ALUP #}%{u_alup}%c01{][WKUP #}%{u_wkup}%c01{]}"

announce.STATS_GROUP_HEADER = "%b{%c01{STATS:}} %c01{[ }%c15{GroupTop} %c01{]}"

announce.STATS_GROUP = "%b{%c01{STATS:}} %b{%{g_rank}}%c01{. }%b{%{g_name}} %c01{[}%{g_mb}MB%c01{/}%{g_files} %c01{Files/}%{g_pct}%c01{%/}%{g_speed}%c01{]}"

announce.STATS_END = "%b{%c01{STATS:}} -----------====>>>>           %c03{END}          <<<<====-----------"

announce.BNC = "%b{%c01{BNC:}} %c01{Checking GoFTPd status, please wait ...}"

announce.BNC_UP = "%c03{%index}.- %c06{%name} %c01{at} %c05{%host}%c01{:}%c05{%port} %c01{is} %c03{UP} %c01{(login:} %c05{%latency}ms%c01{)}"

announce.BNC_DOWN = "%c04{%index}.- %c06{%name} %c01{at} %c05{%host}%c01{:}%c05{%port} %c01{is} %c04{DOWN} %c01{(%error)}"

announce.BNC_ERROR = "%b{%c01{BNC:}} %c04{%response}"

announce.LOGINFAIL = "%b{%c02{LOGiN:}} %c04{%message}"
announce.SLAVEAUTHFAIL = "%b{%c04{SLAVESEC:}} %c07{%message}"
announce.SLOWUPLOADWARN = "%b{%c07{SLOWUP:}} %c05{%message}"
announce.SLOWUPLOADKICK = "%b{%c04{SLOWKICK:}} %c07{%message}"
announce.SLOWDOWNLOADWARN = "%b{%c07{SLOWDN:}} %c05{%message}"
announce.SLOWDOWNLOADKICK = "%b{%c04{SLOWKICK:}} %c07{%message}"

announce.BANNEDCMD_LINE = "%b{%c01{BANNED:}} %c05{%line}"

announce.BANNEDCMD_ERROR = "%b{%c01{BANNED:}} %c04{%response}"

announce.TOPCMD_HEADER = "%c03{TOP UPLOADERS FOR THE DAY:} %c01{[ }%b{%count} %c01{Users ]}"

announce.TOPCMD_ENTRY = "%c01{[ }%c06{%rank} %c01{]} %b{%user} %c01{- (}%b{%files} %c01{Files) - (}%b{%size}%c01{)}"

announce.TOPCMD_TOTAL = "%c03{TOTAL UPLOADS FOR THE DAY:} %c01{( }%b{%files} %c01{Files ) - ( }%b{%size}%c01{)}"

announce.TOPCMD_EMPTY = "%b{%c03{TOP:}} %c05{No uploads recorded for today.}"

announce.TOPCMD_ERROR = "%b{%c03{TOP:}} %c04{%response}"


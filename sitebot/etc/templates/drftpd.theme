announce.BW_LINE = "%c01{%response}"

announce.BW_ERROR = "%b{%c01{BANDWiDTH:}} %c04{%response}"

announce.RULESCMD_LINE = "%b{%c01{RULES:}} %c05{%line}"

announce.RULESCMD_ERROR = "%b{%c01{RULES:}} %c04{%response}"
announce.QUOTACMD_QUOTA_HEADER = "%b{%c02{QUOTA:}} %c05{WEEKLY QUOTA} %c01{[ }%b{%count} %c01{Users - (Min }%b{%quota_gb}%c01{) ]}"
announce.QUOTACMD_QUOTA_ENTRY = "%c01{[ }%c06{%rank} %c01{]} %b{%user}%c01{/}%c06{%group} %c01{( }%b{%size} %c01{Up ) is currently }%b{%status_plain}%c01{.}"
announce.QUOTACMD_TRIAL_HEADER = "%b{%c02{QUOTA:}} %c05{TRIAL QUOTA} %c01{[ Trial List - }%b{%count} %c01{Trialing - (Min }%b{%quota_gb}%c01{) ]}"
announce.QUOTACMD_TRIAL_ENTRY = "%c01{[ }%c06{%rank} %c01{]} %b{%user}%c01{/trial ( }%b{%size} %c01{Up ) is currently }%b{%status_plain}%c01{. (}%b{%days_remaining}%c01{ days left)}"
announce.QUOTACMD_EMPTY = "%b{%c02{QUOTA:}} %c04{No trial or quota users tracked.}"

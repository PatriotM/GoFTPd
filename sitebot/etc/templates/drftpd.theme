announce.NEWDIR = "%b%c01{NEW:}%b %c14{[}%section_colored%c14{]} %c14{%relname} %c01{by }%c%sec_c2{%u_name}"

announce.NEWDAY = "%b%c01{NEW DAY:}%b %c01{-}%section_colored%c01{- A new day has come!} %c%sec_c5{%date} %c01{has been created along with its symlink.}"

announce.AUDIOINFO = "%c01{FLAC} %c01{-> }%c14{%relname}%b %c14{[}%genre%b %c01{from }%year%b %c01{at sample rate }%sample_rate%b %c01{Hz, channels }%channels%b%c14{]}"

announce.MEDIAINFO = "[SAMPLE] %c14{%relname}%b %c01{::} %video_format%b %c01{: }%c05{%{width}}%c01{x}%c05{%{height}} %c01{: }%audio_format%b %c01{: }%channels%b %c01{: }%duration%b"
announce.CUSTOM = "%message"
announce.RELEASEGUARD = "%c04{RELEASEGUARD:} %c05{%message}"
announce.SPACEARCHIVE = "%c14{[SPACE]:} %c09{[ARCHiViNG]} %c14{::} %c14{%relname} %c14{::} %c06{[}%c14{%size_mb} MB%c06{]} %c14{to} %c07{[}%c14{%destination_label}%c07{]}"
announce.SPACEOFFSITE = "%c14{[SPACE]:} %c13{[OFFSiTE]} %c14{::} %c14{%relname} %c14{::} %c06{[}%c14{%size_mb} MB%c06{]} %c14{to} %c07{[}%c14{%destination_label}%c07{]}"
announce.SPACEDELETE = "%c14{[SPACE]:} %c04{[DELETiNG]} %c14{::} %c14{%relname} %c14{::} %c06{[}%c14{%size_mb} MB%c06{]} %c14{from} %c07{[}%c14{%destination_label}%c07{]}"
announce.ARCHIVEINFO = "%c15{ARCHIVE} %c01{[}%c%sec_c2{%orig_section}%c01{] -> }%relname%b %c01{:: }%target_path%b %c01{:: }%size_mb%b%c01{MB :: }%incoming_free_gb%b%c01{GB in :: }%archive_free_gb%b%c01{GB arc}"
announce.ARCHIVEOFFSITE = "%c15{ARCHIVE} %c01{[}%c%sec_c2{%orig_section}%c01{] -> }%relname%b %c01{:: }%target_path%b %c01{:: }%size_mb%b%c01{MB :: offsite}"

announce.SPEEDTEST = "%b%c01{SPEEDTEST:}%b %c04{%nick} %c01{%action} %c01{a} %c05{%{size_mb}MB} %c01{file with} %c06{%speed_mbs}"

announce.SFV_RAR = "%b%c01{RACE:}%b %c14{[}%section_colored%c14{]} %c01{Got SFV for }%c14{%relname} %c01{uploaded by }%c%sec_c2{%u_name}%c01{. Now expecting }%b%c14{%t_filecount}%b %c01{%t_file_label.}"

announce.UPDATE_RAR = "%c01{FIRST} %c01{in }%section_colored%c01{: -> }%c14{%relname} %c01{by }%user%b %c01{at }%speed%b%c01{. Expecting }%size%b %c01{in }%files%b %c01{files.}"

announce.UPDATE_RAR_UNKNOWN = "%c01{FIRST} %c01{in }%section_colored%c01{: -> }%c14{%relname} %c01{by }%user%b %c01{at }%speed%b."

announce.UPDATE_ZIP = "%c01{FIRST} %c01{in }%section_colored%c01{: -> }%c14{%relname} %c01{by }%user%b %c01{at }%speed%b%c01{. Expecting }%size%b %c01{in }%files%b %c01{files.}"

announce.UPDATE_ZIP_UNKNOWN = "%c01{FIRST} %c01{in }%section_colored%c01{: -> }%c14{%relname} %c01{by }%user%b %c01{at }%speed%b."

announce.UPDATE_TRACK = "%c01{FIRST} %c01{in }%section_colored%c01{: -> }%c14{%relname} %c01{by }%user%b %c01{at }%speed%b."

announce.RACE_RAR = "%b%c01{RACE:}%b %c14{[}%section_colored%c14{]} %c14{%relname} %c01{- }%c%sec_c2{%u_name} %c01{joined the race at }%b%c14{%u_speed}%b%c01{.}"

announce.NEWLEADER = "%b%c01{NEW LEADER:}%b %c14{[}%section_colored%c14{]} %c14{%relname} %c01{- }%c%sec_c2{%leaduser} %c01{takes the lead - }%b%c14{%leadsize}%b%c01{/}%b%c14{%leadfiles}F%b%c01{/}%b%c14{%leadpercent}%b%c01{/}%b%c14{%leadspeed}%b %c01{- }%b%c14{%filesleft}%b %c01{files left.}"

announce.HALFWAY = "%b%c01{HALFWAY:}%b %c14{[}%section_colored%c14{]} %c14{%relname} %c01{- avg speed: }%b%c14{%t_avgspeed}%b %c01{- time left: }%b%c14{%t_timeleft}%b %c01{- leader: }%c%sec_c2{%leaduser} %c14{[}%b%c14{%leadsize}%b%c01{/}%b%c14{%leadfiles}F%b%c01{/}%b%c14{%leadpercent}%b%c01{/}%b%c14{%leadspeed}%b%c01{] - }%b%c14{%filesleft}%b %c01{files left.}"

announce.TVINFO = "%c01{RACE:} %c14{[}%section_colored%c14{]} %c01{[TvMaze] }%c07{%title}%c01{ :: }%c07{%network}%c01{ :: }%c07{%type}%c01{ :: }%c07{%genre}%c01{ :: }%c07{%language}%c01{ :: }%link"

announce.MOVIEINFO = "%c01{RACE:} %c14{[}%section_colored%c14{]} %c05{[IMDB]} %c07{%title}%c01{ (}%c07{%year}%c01{)}\n%c01{RACE:} %c14{[}%section_colored%c14{]} %c05{[IMDB]} %c01{Genres: }%c07{%genre}%c01{ :: Language: }%c07{%language}%c01{ :: Country: }%c07{%country}%c01{ :: Director: }%c07{%director}%c01{ :: Scored: }%c07{%rating}/10%c01{ with }%c07{%votes}%c01{ votes :: Runtime: }%c07{%runtime}\n%c01{RACE:} %c14{[}%section_colored%c14{]} %c05{[IMDB]} %c01{Plot: }%c07{%plot}\n%c01{RACE:} %c14{[}%section_colored%c14{]} %c05{[IMDB]} %u{%link}"

announce.COMPLETE = "%b%c01{COMPLETE:}%b %c14{[}%section_colored%c14{]} %c14{%relname} %c01{by }%b%c14{%racers}%b %c01{racers - }%b%c14{%size}%b%c01{/}%b%c14{%files}%b%c01{/}%b%c14{%t_avgspeed}%b%c01{/}%b%c14{%t_duration}%b"

announce.STATS_HOF = "%b%c01{STATS:}%b ▂▃▅▇█▓▒░۩۞۩  %c%sec_c2{Users Hall Of Fame}  ۩۞۩░▒▓█▇▅▃▂"

announce.STATS_SPEEDS = "%b%c01{STATS:}%b %c14{Slowest:} %c%sec_c2{%u_slowest_name} %c14{at} %b%c14{%u_slowest_speed}%b %c14{-} %c14{Fastest:} %c%sec_c2{%u_fastest_name} %c14{at} %b%c14{%u_fastest_speed}%b%c14{.}"

announce.STATS_USER_HEADER = "%b%c01{STATS:}%b %c14{[ }%c%sec_c2{UserTop} %c14{]}"

announce.STATS_USER = "%b%c01{STATS:}%b %c14{[}%c03{%{u_rank}}%c14{]} %c%sec_c2{%{u_name}} %c01{/} %c07{%{u_group}} %c14{-} %b%c14{%{u_files}f}%b %c14{-} %b%c14{%{u_mb}MB}%b %c14{-} %b%c14{%{u_pct}%}%b %c14{-} %b%c14{%{u_speed}}%b %c14{[ }%c14{ALLUP} %c03{#%{u_alup}} %c14{] [ }%c14{WKUP} %c03{#%{u_wkup}} %c14{]}"

announce.STATS_GROUP_HEADER = "%b%c01{STATS:}%b %c14{[ }%c%sec_c2{GroupTop} %c14{]}"

announce.STATS_GROUP = "%b%c01{STATS:}%b %c14{[}%c03{%{g_rank}}%c14{]} %c07{%{g_name}} %c14{-} %b%c14{%{g_files}f}%b %c14{-} %b%c14{%{g_mb}MB}%b %c14{-} %b%c14{%{g_pct}%}%b %c14{-} %b%c14{%{g_speed}}%b"

announce.STATS_END = "%b%c01{STATS:}%b -----------====>>>>           %c%sec_c5{END}          <<<<====-----------"

announce.BNC = "%c01{BNC:} %c01{Checking %{sitename} status, please wait ...}"

announce.BNC_UP = "%c03{%index}.- %c06{%name} %c01{at} %c05{%host}%c01{:}%c05{%port} %c01{is} %c03{UP} %c01{(login:} %c05{%latency}ms%c01{)}"

announce.BNC_DOWN = "%c04{%index}.- %c06{%name} %c01{at} %c05{%host}%c01{:}%c05{%port} %c01{is} %c04{DOWN} %c01{(%error)}"

announce.BNC_ERROR = "%c01{BNC:} %c04{%response}"

announce.LOGINFAIL = "%c02{LOGiN:} %c04{%message}"
announce.SLAVEAUTHFAIL = "%c04{SLAVESEC:} %c07{%message}"
announce.SLOWUPLOADWARN = "%c07{SLOWUP:} %c05{%message}"

announce.TOPCMD_ENTRY = "%c14{[}%c03{%rank}%c14{]} %c06{%user}%c01{/}%c07{%group} %c01{- (}%c03{%files} %c01{Files) - (}%c05{%size}%c01{)}"

announce.TOPCMD_TOTAL = "%c03{TOTAL UPLOADS FOR THE DAY:} %c01{( }%c01{%files} %c01{Files ) - ( }%c01{%size}%c01{)}"


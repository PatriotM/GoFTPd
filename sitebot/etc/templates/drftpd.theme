announce.UNNUKE = "%b{%c15{UNNUKE}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{by }%b{%user}%b"

announce.PRE = "%b{%c15{PRE}} %c01{in }%section_colored%c01{: -> }%b{%group}%b %c01{gives us }%b{%relname}%b %c01{(}%b{%t_files}%b %c01{files - }%b{%t_mbytes}%b%c01{).}%pre_suffix"
announce.PREAUDIOINFO = "%b{%c15{PRE}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{:: }%b{%pre_audio_head}%b %c01{:: }%b{%genre}%b %c01{:: }%b{%year}%b %c01{:: }%b{%bitrate}%b"
announce.PREMOVIEINFO = "%b{%c15{PRE}} %c01{in }%section_colored%c01{: -> }%b{%relname}%b %c01{:: }%b{%title}%b %c01{(}%b{%year}%b%c01{) :: }%b{%genre}%b %c01{:: }%b{%rating}%b"

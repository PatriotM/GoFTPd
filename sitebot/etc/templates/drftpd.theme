announce.PREBW = "%b{[}%section_colored%b{]} %c14{-PREBW-} %relname %c01{:: Leeched: }%b{%traffic_val}%b%traffic_unit %c01{:: Average speed: }%b{%avg_val}%b%avg_unit %c01{:: Best: }%b{%peak_val}%b%peak_unit"


############################################################
#  GoFTPd sitebot theme — light background friendly         #
#  All colors are dark shades readable on white/light mIRC: #
#    c02 = blue                                              #
#    c03 = green                                             #
#    c04 = red                                               #
#    c05 = brown                                             #
#    c06 = purple                                            #
#    c10 = teal/cyan                                         #
#    c13 = pink/magenta                                      #
#  Avoids: c00 (white), c08 (yellow), c09 (light green),    #
#          c11 (light cyan), c14/15 (greys)                 #
############################################################

COLOR_DEFAULT_1 = "03"
COLOR_DEFAULT_2 = "02"
COLOR_DEFAULT_3 = "06"
COLOR_DEFAULT_4 = "04"
COLOR_DEFAULT_5 = "05"

COLOR_0DAY_1 = "14"
COLOR_0DAY_2 = "02"
COLOR_0DAY_3 = "14"
COLOR_0DAY_4 = "02"
COLOR_0DAY_5 = "07"

COLOR_EBOOKS_1 = "14"
COLOR_EBOOKS_2 = "02"
COLOR_EBOOKS_3 = "14"
COLOR_EBOOKS_4 = "02"
COLOR_EBOOKS_5 = "07"

COLOR_MP3_1 = "03"
COLOR_MP3_2 = "05"
COLOR_MP3_3 = "06"
COLOR_MP3_4 = "04"
COLOR_MP3_5 = "10"

COLOR_FLAC_1 = "10"
COLOR_FLAC_2 = "05"
COLOR_FLAC_3 = "06"
COLOR_FLAC_4 = "04"
COLOR_FLAC_5 = "03"

announce.NEWDIR = "%b{%c%sec_c1{NEW :}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{by} %c%sec_c4{%u_name}"

announce.NEWDAY = "%b{%c%sec_c1{NEW DAY:}} %c01{-}%section_colored%c01{- A new day has come!} %c%sec_c5{%date} %c01{has been created along with its symlink.}"

announce.AUDIOINFO = "%b{%c%sec_c1{AUDIO-INFO:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{Get ready for some} %c%sec_c5{%genre} %c01{from} %c%sec_c5{%year} %c01{at} %c%sec_c5{%sample_rate}Hz %c01{in} %c%sec_c5{%channels} %c%sec_c5{%bitrate} %c01{(}%c%sec_c5{%bitrate_mode}%c01{).}"

announce.MEDIAINFO = "%b{%c%sec_c1{SAMPLE-INFO:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{Video:} %c%sec_c5{%video_format} %c01{%width}x%height %c01{- Audio:} %c%sec_c5{%audio_format} %c01{%channels} %c01{- Subs:} %c%sec_c5{%subtitle_format} %c01{- Duration:} %c%sec_c5{%duration}"

announce.SPEEDTEST = "%b{%c03{SPEEDTEST:}} %c04{%nick} %c01{%action} %c01{a} %c05{%{size_mb}MB} %c01{file with} %c06{%speed_mbs}"

announce.SFV_RAR = "%b{%c%sec_c1{RACE:}} %c01{[}%section_colored%c01{]} Got SFV for %c%sec_c3{%b{%relname}} %c01{uploaded by} %c%sec_c4{%u_name}%c01{. Now expecting} %c%sec_c5{%b{%t_filecount}} %c01{%t_file_label.}"

announce.UPDATE_RAR = "%b{%c%sec_c1{RACE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{got its first rar file from} %c%sec_c4{%u_name} %c01{at} %c%sec_c5{%u_speed}%c01{. Now expecting} %c%sec_c5{%b{%t_mbytes}}%c01{.}"

announce.UPDATE_RAR_UNKNOWN = "%b{%c%sec_c1{RACE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{got its first rar file from} %c%sec_c4{%u_name} %c01{at} %c%sec_c5{%u_speed}%c01{.}"

announce.UPDATE_TRACK = "%b{%c%sec_c1{RACE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{got first track from} %c%sec_c4{%u_name} %c01{at} %c%sec_c5{%u_speed}%c01{.}"

announce.RACE_RAR = "%b{%c%sec_c1{RACE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{-} %c%sec_c4{%u_name} joined the race %c01{at} %c%sec_c5{%u_speed}%c01{.}"

announce.NEWLEADER = "%b{%c04{NEW LEADER:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{-} %c%sec_c4{%leader_name} %c01{takes the lead -} %c%sec_c5{%{leader_mb}MB}%c01{/}%c%sec_c5{%{leader_files}F}%c01{/}%c%sec_c5{%{leader_pct}%}%c01{/}%c%sec_c5{%leader_speed} %c01{-} %c%sec_c5{%t_filesleft} %c01{files left.}"

announce.HALFWAY = "%b{%c13{HALFWAY:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{- avg speed:} %c%sec_c5{%t_avgspeed} %c01{- time left:} %c%sec_c5{%t_timeleft} %c01{- leader:} %c%sec_c4{%leader_name} %c01{[}%c%sec_c5{%{leader_mb}MB}%c01{/}%c%sec_c5{%{leader_files}F}%c01{/}%c%sec_c5{%{leader_pct}%}%c01{/}%c%sec_c5{%leader_speed}%c01{] -} %c%sec_c5{%t_filesleft} %c01{files left.}"

announce.TVINFO = "%b{%c%sec_c1{TV-INFO:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{Genre:} %c%sec_c5{%genre} %c01{- Type:} %c%sec_c5{%b{%type}} %c01{- Link:} %c%sec_c5{%link}\n%b{%c%sec_c1{TV-INFO:}} %c01{[}%section_colored%c01{]} %c01{Network:} %c%sec_c5{%b{%network}} %c01{- Rating:} %b{%c%sec_c5{%rating}} %c01{- Language:} %c%sec_c5{%language}"

announce.MOVIEINFO = "%b{%c%sec_c1{MOVIE-INFO:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%title}} %c01{(}%c%sec_c5{%year}%c01{)} %c01{-} %c%sec_c5{%genre} %c01{-} %b{%c%sec_c5{%rating}}/10 %c01{(}%c%sec_c5{%votes} votes%c01{) - Metacritic:} %c%sec_c5{%metacritic} %c01{-} %c%sec_c5{%runtime} %c01{-} %c%sec_c5{%language} %c01{-} %c%sec_c5{%link}\n%b{%c%sec_c1{MOVIE-INFO:}} %c01{[}%section_colored%c01{]} %c01{Director:} %c%sec_c4{%director} %c01{- Stars:} %c%sec_c4{%stars}"

announce.COMPLETE = "%b{%c%sec_c1{COMPLETE:}} %c01{[}%section_colored%c01{]} %c%sec_c3{%b{%relname}} %c01{by} %c%sec_c5{%u_count} %c01{racers -} %c%sec_c5{%t_mbytes}%c01{/}%c%sec_c5{%t_files}%c01{/}%c%sec_c5{%t_avgspeed}%c01{/}%c%sec_c5{%t_duration}"

announce.STATS_HOF = "%b{%c02{STATS:}} ▂▃▅▇█▓▒░۩۞۩  %c03{Users Hall Of Fame} ۩۞۩░▒▓█▇▅▃▂"

announce.STATS_SPEEDS = "%b{%c02{STATS:}} %c01{Slowest:} %c04{%u_slowest_name} %c01{at} %c05{%u_slowest_speed} %c01{-} %c01{Fastest:} %c04{%u_fastest_name} %c01{at} %c05{%u_fastest_speed}%c01{.}"

announce.STATS_USER = "%b{%c02{STATS:}} %c01{[}%c03{%u_rank}%c01{]} %c04{%u_name}%c01{/}%c06{%u_group} %c01{-} %c05{%b{%{u_files}f}} %c01{-} %c05{%b{%{u_mb}MB}} %c01{-} %c05{%b{%{u_pct}%}} %c01{-} %c05{%u_speed}"

announce.STATS_END = "%b{%c02{STATS:}} -----------====>>>>           %c03{END}          <<<<====-----------"

announce.NUKE = "%b{%c04{NUKE:}} %c01{[}%section_colored%c01{]} %c06{%b{%relname}} %c01{by} %c04{%u_name}"

announce.UNNUKE = "%b{%c03{UNNUKE:}} %c01{[}%section_colored%c01{]} %c06{%b{%relname}} %c01{by} %c04{%u_name}"

announce.PRE = "%b{%c04{PRE:}} %c01{[}%section_colored%c01{]} %c06{%b{%relname}} %c01{by} %c04{%b{%group}} %c01{(}%c04{%user}%c01{)} %c01{-} %c05{%t_mbytes}%c01{/}%c05{%t_files}"

announce.PREBW = "%b{%c02{PREBW:}} %c01{[}%section_colored%c01{]} %c01{::} %c06{%b{%relname}} %c01{::} %c03{%b{%traffic_val}}%c01{%traffic_unit} %c01{@} %c03{%b{%avg_val}}%c01{%avg_unit} %c01{:: Highest} %c03{%b{%peak_val}}%c01{%peak_unit}"

announce.PREBWINTERVAL = "%b{%c02{PREBW:}} %c01{[}%section_colored%c01{]} %c01{::} %c03{%b{%b1}}%c01{%u1 @} %c03{%t1}%c01{s ::} %c03{%b{%b2}}%c01{%u2 @} %c03{%t2}%c01{s ::} %c03{%b{%b3}}%c01{%u3 @} %c03{%t3}%c01{s ::} %c03{%b{%b4}}%c01{%u4 @} %c03{%t4}%c01{s ::} %c03{%b{%b5}}%c01{%u5 @} %c03{%t5}%c01{s :: Highest} %c03{%b{%peak_val}}%c01{%peak_unit}"

announce.PREBWUSER = "%b{%c02{PREBW:}} %c01{[}%section_colored%c01{]} %c01{::} %c04{%b{%user}} %c01{::} %c03{%b{%size_val}}%c01{%size_unit}%c01{/}%c03{%b{%cnt_files}}%c01{F @} %c03{%b{%avg_val_user}}%c01{%avg_unit_user} %c01{:: Highest} %c03{%b{%peak_val_user}}%c01{%peak_unit_user}"

announce.DF_SLAVE = "%b{%c02{DF:}} %c06{%b{%slave}} %c01{-} %c03{%free} %c01{free /} %c05{%total} %c01{total (}%c03{%{free_pct}%}%c01{ free) [}%c04{%state}%c01{]}"

announce.DF_TOTAL = "%b{%c02{DF:}} %c06{%b{TOTAL}} %c01{-} %c03{%free} %c01{free /} %c05{%total} %c01{total (}%c03{%{free_pct}%}%c01{ free)}"

announce.DF_EMPTY = "%b{%c02{DF:}} %c04{No slave disk status received yet.}"

announce.DF_NOMATCH = "%b{%c02{DF:}} %c04{No slave matched} %c05{%filter}"

# This file holds autonuke settings only.
# Enable/disable the daemon plugin from etc/config.yml -> plugins.autonuke.

# Autonuke scans the sections listed below, keeps state/history in state_dir,
# and uses a local FTP account to execute the normal SITE NUKE command.

# Local daemon login used for SITE NUKE / SITE WIPE.
host: "127.0.0.1"
port: 21212
user: "NUKEBOT"
password: "change-me"
tls: true
insecure_skip_verify: true
timeout_seconds: 10

# Persistent state for warning/lock files.
# Also stores history.jsonl with warn/nuke/skip/cleanup events.
state_dir: "logs/autonuke"

# Prefix used by normal nukes on site.
nuked_prefix: "[NUKED]-"

# Polling interval.
scan_interval_seconds: 600

# Sections to scan.
# Use the actual section path shape you use on the site.
# Dated sections can use the same readable tokens as the dateddirs plugin:
#   MM   = month
#   DD   = day
#   YY   = 2-digit year
#   YYYY = 4-digit year
#   WW   = ISO week
# Examples:
#   - "/TV-1080P/*"
#   - "/FOREIGN/TV-DE/*"
#   - "/MP3/MMDD/*"
#   - "/0DAY/YYYY-MM-DD/*"
sections:
  - "/0DAY/MMDD/*"
  - "/APPS/*"
  - "/BLURAY/*"
  - "/BLURAY-UHD/*"
  - "/DVDR/*"
  - "/EBOOKS/MMDD/*"
  - "/FLAC/MMDD/*"
  - "/FOREIGN/TV-CZ/*"
  - "/FOREIGN/TV-DE/*"
  - "/FOREIGN/TV-DK/*"
  - "/FOREIGN/TV-ES/*"
  - "/FOREIGN/TV-FI/*"
  - "/FOREIGN/TV-FR/*"
  - "/FOREIGN/TV-IT/*"
  - "/FOREIGN/TV-NL/*"
  - "/FOREIGN/TV-NO/*"
  - "/FOREIGN/TV-PL/*"
  - "/FOREIGN/TV-SE/*"
  - "/FOREIGN/TV-SK/*"
  - "/FOREIGN/X264-HD-FOREIGN/*"
  - "/FOREIGN/X264-SD-FOREIGN/*"
  - "/FOREIGN/X265-FOREIGN/*"
  - "/GAMES/*"
  - "/MBLURAY/*"
  - "/MDVDR/*"
  - "/MVID/*"
  - "/MP3/MMDD/*"
  - "/NSW/*"
  - "/PS5/*"
  - "/TV-1080P/*"
  - "/TV-2160P/*"
  - "/TV-720P/*"
  - "/TV-BLURAY/*"
  - "/TV-HDRIP/*"
  - "/TV-SD/*"
  - "/TV-SPORTS/*"
  - "/X264-HD-1080P/*"
  - "/X264-HD-720P/*"
  - "/X264-SD/*"
  - "/X265/*"
  - "/XXX-0DAY/MMDD/*"
  - "/XXX-HD/*"
  - "/XXX-IMAGESETS/*"
  - "/XXX-SD/*"

# Legacy-style extra roots to ignore. PRE child dirs are added dynamically to
# the exclude list at runtime.
affils_dirs:
  - "/PRE"

# Release names containing these substrings are skipped entirely.
exclude_name_contains:
  - "PRE"
  - "nfofix"
  - "nfo.fix"
  - "nfo.update"
  - "dirfix"
  - "dir.fix"
  - "sample.fix"
  - "samplefix"
  - "repack"
  - ".fix."
  - "_fix_"
  - "missing"
  - "COMPLETE"

# Markers that count as "approved" and keep a release out of autonuke.
approval_markers:
  - "[Approved_by_"
  - ".approved"
  - ".allow"
check_complete_dir: true

# Excluded from the nukees output shown in announces.
user_exclude: "goftpd"

empty:
  enabled: true
  warn_enabled: true
  warn_after_min: 60
  nuke_after_min: 240
  multiplier: 10
  reason: "Empty"

half_empty:
  enabled: true
  warn_enabled: true
  warn_after_min: 60
  nuke_after_min: 240
  multiplier: 10
  reason: "Half-Empty"
  payload_extensions:
    - "mpg"
    - "m2v"
    - "mpeg"
    - "zip"
    - "rar"
    - "r00"
    - "r01"
    - "mp3"
    - "000"
    - "001"
    - "flac"
    - "mkv"

incomplete:
  enabled: true
  warn_enabled: true
  warn_after_min: 60
  nuke_after_min: 240
  multiplier: 10
  reason: "Incomplete"
  jump_on:
    - "CD1"
    - "CD2"
    - "CD3"
    - "CD4"
    - "CD5"
    - "CD6"
    - "CD7"
    - "DISC1"
    - "DISC2"
    - "DISC3"
    - "DISC4"
    - "DVD1"
    - "DVD2"
    - "DVD3"
    - "DVD4"
    - "D01"
    - "D02"
    - "D03"
    - "D04"

# Legacy BANDIRS/ALLOWDIRS can still be used via upper-case keys if you prefer.
banned:
  enabled: true
  warn_enabled: true
  warn_after_min: 1
  nuke_after_min: 1
  default_multiplier: 10
  rules:
    - path: "/MP3/*/*"
      patterns: ["-FLAC-"]
      multiplier: 10
      description: "Banned release naming"
    - path: "/X265/*"
      patterns: [".MULTI."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/X264-SD/*"
      patterns: [".MULTI."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/X264-HD-720P/*"
      patterns: [".MULTI."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/X264-HD-1080P/*"
      patterns: [".MULTI."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/TV-SD/*"
      patterns: ["MULTI"]
      multiplier: 10
      description: "Banned release naming"
    - path: "/TV-720P/*"
      patterns: ["MULTI", "BLURAY"]
      multiplier: 10
      description: "Banned release naming"
    - path: "/TV-2160P/*"
      patterns: ["MULTI", "BLURAY"]
      multiplier: 10
      description: "Banned release naming"
    - path: "/TV-1080P/*"
      patterns: ["MULTI", "BLURAY"]
      multiplier: 10
      description: "Banned release naming"
    - path: "/BLURAY/*"
      patterns: [".D01.", ".D02.", ".D03."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/APPS/*"
      patterns: [".BLURAY.", ".MULTI."]
      multiplier: 10
      description: "Banned release naming"
    - path: "/GAMES/*"
      patterns: ["_NSW", ".PS4.", ".PS5."]
      multiplier: 10
      description: "Banned release naming"

allowed:
  enabled: false
  warn_enabled: true
  warn_after_min: 1
  nuke_after_min: 20
  default_multiplier: 3
  rules: []

delete_nukes:
  enabled: true
  delete_after_min: 180

# Sections where the daemon-side IMDb helper should run.
sections: ["BLURAY", "BLURAY-UHD", "DVDR", "MBLURAY", "MDVDR", "X264-HD-720P", "X264-HD-1080P", "X264-SD", "X265", "X264-HD-FOREIGN", "X264-SD-FOREIGN", "X265-FOREIGN"]

# Optional outbound proxy for lookups.
# Examples:
# proxy: "socks5h://127.0.0.1:9050"
# proxy: "http://127.0.0.1:8080"
proxy: ""

debug: false

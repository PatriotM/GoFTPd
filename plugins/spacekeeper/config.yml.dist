# This file holds spacekeeper settings only.
# Enable/disable the daemon plugin from etc/config.yml -> plugins.spacekeeper.

# Spacekeeper watches reported free space on specific slaves and deletes the
# oldest matching releases when a slave drops under the configured threshold.
#
# Supported actions:
# - delete_oldest
#     Real free-space relief. Deletes the oldest eligible release until the
#     target free-space threshold is reached.
# - archive_oldest
#     Low-space archive relocation. When the watched source slave drops below
#     trigger_free_*, moves the oldest eligible release into the configured
#     destination path until the source slave is estimated back above
#     target_free_*. If that destination path routes to another slave,
#     spacekeeper will copy it there in the background and then remove the
#     source when the copy finishes cleanly. You can also force one or more
#     specific archive slaves with target_slaves. Optional destination_dated
#     support can place archived releases in date buckets like /ARCHiVE/EBOOKS/0514.
#
# Rules are written in virtual FTP paths, not disk paths or devices.
# Active transfers, incomplete races, and dated bucket dirs can be skipped
# safely by the built-in candidate checks.
# Threshold keys can use either the original names:
#   trigger_free_gb / target_free_gb
# or the clearer aliases:
#   incoming_disk_threshold_min_gb / incoming_disk_threshold_target_gb
# Optional watch_mount_path lets one slave monitor free space for a specific
# virtual root only, such as "/" for the live site, "/ARCHiVE" for local
# archive mounts, or "/OFFSITE" for offsite mounts exposed through
# mounted_roots.
# If target_slaves is set and none of them currently has enough free space,
# spacekeeper deletes the oldest archived release(s) under destination on one
# of those archive slaves until the incoming release fits there.
#
# Archive jobs run in the background so normal plugin evaluation does not block
# behind a large move.

# How often to evaluate all rules.
interval_seconds: 60

# Global switches for the two sides of the plugin.
enable_freespace_actions: true
enable_archive_actions: true

rules:
  # When SLAVE1 drops below 50 GiB free, delete the oldest eligible release
  # from the listed paths until we estimate the slave is back above 80 GiB.
  - name: "0day-space"
    slave: "SLAVE1"
    action: "delete_oldest"
    # Optional: watch free space only for this mount path on the slave.
    # "/" is usually your live site root. If omitted, the whole slave total
    # is used.
    watch_mount_path: "/"
    # No destination here: delete rules only need paths + thresholds.

    # Candidate release directories. These are virtual paths, not disk paths.
    paths:
      - "/0DAY/*/*"
      - "/MP3/*/*"

    # The cleanup starts below trigger_free_* and stops once target_free_*
    # has been reached or there is nothing left that matches.
    trigger_free_gb: 50
    target_free_gb: 80
    # Same thresholds using the clearer alias names:
    # incoming_disk_threshold_min_gb: 50
    # incoming_disk_threshold_target_gb: 80

    # Do not touch releases newer than this.
    min_age_seconds: 600

    # Skip releases that still look incomplete according to cached race data.
    skip_incomplete: true

    # Skip releases with active uploads/downloads inside them.
    skip_active_races: true

    # Safety limit for one cycle of this rule.
    max_actions_per_cycle: 10

  # When SLAVE1 gets low on free space, archive the oldest completed 0DAY
  # release(s) into /ARCHiVE/0DAY until we estimate the slave is back above
  # the target threshold. If your slave routing sends /ARCHiVE/* to another
  # slave, this becomes a real cross-slave archive move.
  - name: "0day-archive"
    slave: "SLAVE1"
    action: "archive_oldest"
    # Watch only the live site root for this decision.
    watch_mount_path: "/"
    # Archive rules use destination because they move releases instead of
    # deleting them directly.
    destination: "/ARCHiVE/0DAY"
    # Optional: append a dated subdir under destination based on the release
    # mtime. Format tokens match dateddirs (MMDD, YYYYMMDD, YYYY-WW, etc).
    destination_dated: true
    destination_date_format: "MMDD"
    # Optional explicit archive pool. If omitted, normal upload routing for
    # destination decides where the archive lands.
    target_slaves: ["SLAVE2", "SLAVE3"]
    paths:
      - "/0DAY/*/*"
    incoming_disk_threshold_min_gb: 40
    incoming_disk_threshold_target_gb: 60
    min_age_seconds: 86400
    skip_incomplete: true
    skip_active_races: true
    max_actions_per_cycle: 3

  # Example 2-tier flow on one slave with mounted_roots:
  # 1. live site "/" archives into "/ARCHiVE"
  # 2. local archive "/ARCHiVE" archives into "/OFFSITE"
  # 3. offsite "/OFFSITE" deletes oldest when full
  - name: "ebooks-local-to-offsite"
    slave: "LOCAL"
    action: "archive_oldest"
    watch_mount_path: "/ARCHiVE"
    destination: "/OFFSITE/EBOOKS"
    destination_dated: true
    destination_date_format: "MMDD"
    paths:
      - "/ARCHiVE/EBOOKS/*/*"
    trigger_free_gb: 200
    target_free_gb: 400
    min_age_seconds: 86400
    skip_incomplete: true
    skip_active_races: true
    max_actions_per_cycle: 5

  - name: "ebooks-offsite-delete"
    slave: "LOCAL"
    action: "delete_oldest"
    watch_mount_path: "/OFFSITE"
    paths:
      - "/OFFSITE/EBOOKS/*/*"
    trigger_free_gb: 100
    target_free_gb: 250
    min_age_seconds: 86400
    skip_incomplete: true
    skip_active_races: true
    max_actions_per_cycle: 5

debug: false

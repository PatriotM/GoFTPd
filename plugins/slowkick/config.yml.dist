# This file holds slowkick settings only.
# Enable/disable the daemon plugin from etc/config.yml -> plugins.slowkick.

# Slow transfer kicker.
#
# The actual slow-transfer abort now happens in the live slave transfer loop,
# similar to DrFTPD. This config provides the transfer policy:
# min speed floors, path/user/group exclusions, and optional tempban/announce.

# Watch uploads and/or downloads.
monitor_uploads: true
monitor_downloads: true

# Upload-specific floor in KB/s.
min_upload_speed_kbps: 25
# Grace period before upload minspeed enforcement starts.
verify_upload_seconds: 5

# Download-specific floor in KB/s.
min_download_speed_kbps: 50
# Grace period before download minspeed enforcement starts.
verify_download_seconds: 5

# Do nothing unless at least this many logged-in users are online.
min_users_online: 2

# Never kick these FTP users.
exclude_users: []

# Never kick users whose primary group matches one of these names.
exclude_groups: ["SiteOP"]

# Paths that should never be touched by the plugin.
exclude_paths:
  - "/PRE"
  - "/REQUESTS"
  - "/SPEEDTEST"

# File extensions that should never trigger slowkick.
# Use bare extensions without the leading dot.
exclude_extensions:
  - sfv

# Announce the actual slow abort/kick event.
announce_kick: true

# Temporarily block the same FTP user from logging straight back in after a
# slow kick and grabbing another slot.
tempban_after_kick: true
tempban_seconds: 15

debug: false

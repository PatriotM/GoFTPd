# Block bad release names before MKD creates the directory.
#
# This is a GoFTPd-native take on glftpd/tur-predircheck style rules.

skip_paths:
  - "/PRE/*"
  - "/REQUESTS/*"
  - "/LINKS/*"
  - "/SPEEDTEST/*"

# Basic name hygiene checks.
deny_same_name_in_parent: true
deny_case_conflicts: true
check_nuked_names: true
nuked_prefixes: ["[NUKED]-"]

# Send rejected MKD attempts to staff IRC via the sitebot RELEASEGUARD route.
announce_rejects: true

debug: false

# Block release groups by regex.
deny_groups:
  - path: "/"
    pattern: "-BADGROUP$"

# Block release names by regex.
deny_dirs:
  - path: "/"
    pattern: "^\\[NUKED\\]"

  # TV-style releases belong in TV-BLURAY, not BLURAY.
  # Matches S01E01 and S01D01 style names.
  - path: "/BLURAY"
    pattern: "(?i)(^|[._ -])S[0-9]{2}[ED][0-9]{2}([._ -]|$)"

# Allow-only rules by path/section.
# If one or more allow rules match the target path, the release name must
# match at least one of those rule regexes or MKD is denied.
#
# Example: only allow TV episode-style names in /TV-FR.
# This blocks unrelated documentaries or movie-style releases from being MKD'd
# in that section.
# allow_dirs:
#   - path: "/TV-FR/*"
#     pattern: "\\.S[0-9]{2}E[0-9]{2}\\."
#
# Example: allow both normal episodic TV and daily shows in /TV-NO.
# allow_dirs:
#   - path: "/TV-NO/*"
#     pattern: "\\.S[0-9]{2}E[0-9]{2}\\."
#   - path: "/TV-NO/*"
#     pattern: "\\.[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\."
#
# Example: stricter documentary bucket that only accepts YEAR in the dirname.
# allow_dirs:
#   - path: "/DOCU/*"
#     pattern: "\\.(19|20)[0-9]{2}\\."
allow_dirs: []
